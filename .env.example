# Environment variables for Portfolio Manager

# Gemini AI API Key (Google Generative AI)
# Required for transaction extraction from broker statements using AI
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Portfolio Manager Server Configuration
# Required for server authentication when using local API mode
SECRET_KEY=your-secret-key-here
PORTF_SECRET_KEY=your-portfolio-secret-key-here

# Database Configuration (optional)
# Uncomment and modify if using a custom database URL
# DATABASE_URL=sqlite:///portfolio.db
# DATABASE_URL=postgresql://user:password@localhost:5432/portfolio_db

# Server Configuration (optional)
# Uncomment and modify if running the web server
# HOST=localhost
# PORT=5000
# DEBUG=false

# External Finance API Configuration (optional)
# The update-prices command uses yfinance by default (no API key required)
# If using alternative finance APIs in the future, add their keys here:
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# FINANCIAL_MODELING_PREP_API_KEY=your_fmp_key_here

# Google Sheets Export Configuration
# Service Account credentials file for Google Sheets API access
# Create a service account in Google Cloud Console, enable Google Sheets API,
# and download the JSON credentials file
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/your/service-account-key.json

# Optional: Specific Google Spreadsheet ID to export to
# If not provided, a new spreadsheet will be created for each export
# You can find the ID in the spreadsheet URL: https://docs.google.com/spreadsheets/d/\{SPREADSHEET_ID\}/
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Database backup (~/scripts/portf-backup.sh, daily cron at 03:00)
# Backups are gzip-compressed SQLite snapshots. PFM_BACKUP_DIR is also read by
# POST /api/v1/system/restore to auto-save a pre-restore snapshot before replacing the DB.
PFM_BACKUP_DIR=/home/youruser/backups/pfm
PFM_BACKUP_KEEP=30
