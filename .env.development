# Development Environment Configuration
PORTF_ENVIRONMENT=development
PORTF_DEBUG=true
PORTF_RELOAD=true
PORTF_HOST=localhost
PORTF_PORT=8000
PORTF_WORKERS=1
PORTF_LOG_LEVEL=debug

# Database configuration
PORTF_DATABASE_URL=postgresql://portf_user:portf_password@localhost:5432/portf_db

# Security (development only)
PORTF_SECRET_KEY=development-secret-key

# PostgreSQL Database Configuration for Docker Compose
POSTGRES_USER=portf_user
POSTGRES_PASSWORD=portf_password
POSTGRES_DB=portf_db
POSTGRES_PORT=5432

# Legacy database URL for backward compatibility
DATABASE_URL=postgresql://portf_user:portf_password@localhost:5432/portf_db

# Optional: Set timezone
PGTZ=UTC

# External services (optional)
# PORTF_GEMINI_API_KEY=your-development-gemini-api-key
